{
  "name": "abyssfetch",
  "version": "1.0.0",
  "description": "Deep fetch. Local only. No install required.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "AbyssFetch",
  "license": "MIT",
  "dependencies": {
    "electron": "^28.3.3",
    "express": "^4.18.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.abyssfetch.app",
    "productName": "AbyssFetch",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": ["**/*"]
      }
    ],
    "extraFiles": [
      {
        "from": "portable",
        "to": "portable",
        "filter": ["**/*"]
      },
      {
        "from": "downloads",
        "to": "downloads",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  }
}
