{
  "name": "abyssfetch",
  "version": "1.0.0",
  "description": "Deep fetch. Local only. No install required.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js --ignore-pattern 'node_modules/*' --ignore-pattern 'dist/*'",
    "lint:fix": "eslint . --ext .js --fix --ignore-pattern 'node_modules/*' --ignore-pattern 'dist/*'",
    "format": "prettier --write '**/*.{js,json,md}' --ignore-path .gitignore"
  },
  "author": "AbyssFetch",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "uuid": "^14.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.4.2",
    "prettier": "^3.8.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "app/backend/**/*.js",
      "!app/backend/server.js",
      "!**/node_modules/**"
    ]
  },
  "build": {
    "appId": "com.abyssfetch.app",
    "productName": "AbyssFetch",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraFiles": [
      {
        "from": "portable",
        "to": "portable",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "downloads",
        "to": "downloads",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  }
}
